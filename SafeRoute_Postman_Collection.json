		{
			"name": "Trusted Contacts",
			"item": [
				{
					"name": "Create Trusted Contact Request",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const data = pm.response.json();",
									"if (data.request && data.request.id) {",
									"    pm.collectionVariables.set('trusted_contact_request_id', data.request.id);",
									"}",
									"if (data.accept_token) {",
									"    pm.collectionVariables.set('trusted_contact_accept_token', data.accept_token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Emergency Contact\",\n    \"phone\": \"+91 88888 22222\",\n    \"email\": \"helper@example.com\"\n}"
						},
