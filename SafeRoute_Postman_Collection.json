				{
					"name": "Create Report",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const body = pm.response.json();",
									"    if (body.report && body.report.id) {",
