							"host": [
								"{{base_url}}"
							],
							"path": [
								"reports"
							]
						},
						"description": "Create a new incident report. This request requires the auth cookies set by Register or Login to already exist in Postman's cookie jar for localhost. On success, the Postman test script stores `report_id` automatically."
