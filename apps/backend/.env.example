APP_NAME=SafeRoute Backend
APP_ENV=development
PORT=8080
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUTH_ACCESS_COOKIE_NAME=saferoute_access
AUTH_REFRESH_COOKIE_NAME=saferoute_refresh
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_SECURE=false
EVIDENCE_STORAGE_ROOT=/tmp/saferoute-evidence
MAX_EVIDENCE_SIZE_BYTES=10485760
REPORTS_NEARBY_DEFAULT_LIMIT=20
REPORTS_NEARBY_MAX_LIMIT=50
REPORTS_NEARBY_MAX_RADIUS_METERS=5000
SAFETY_DEFAULT_RADIUS_METERS=500
SAFETY_MAX_RADIUS_METERS=3000
SAFETY_RECENT_WINDOW=6h

POSTGRES_DB=saferoute
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/saferoute?sslmode=disable

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
